# ─────────────────────────────────────────────────────────────
# LTA-WMS Frontend — Environment variables
# Copy to `.env` (local) / `.env.development` / `.env.production`.
# Only variables prefixed with VITE_ are exposed to the client.
# ─────────────────────────────────────────────────────────────

# Base URL of the WMS backend API gateway.
VITE_API_BASE_URL=http://localhost:8080

# Common API path prefix appended to the base URL.
VITE_API_PREFIX=/api/v1

# Request timeout in milliseconds.
VITE_API_TIMEOUT=30000

# Application metadata.
VITE_APP_NAME=LTA-WMS
VITE_APP_ENV=development

# Feature flags (comma-separated).
VITE_FEATURE_FLAGS=
